# Asset Management System — Environment Variables

# ---- Database ----
DATABASE_URL=postgresql://assetuser:assetpass@db:5432/assetdb
POSTGRES_USER=assetuser
POSTGRES_PASSWORD=assetpass
POSTGRES_DB=assetdb

# ---- LLM Provider (Groq) ----
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
